<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.leosystems.bingie.lastshipplayer"
       name="LeoSystems Bingie Lastship Player Installer"
       version="1.0.0"
       provider-name="LeoSystems">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.service" library="service.py" start="startup" />

    <extension point="xbmc.addon.metadata">
        <summary lang="de_DE">Installiert und aktiviert den Lastship-Player für TMDB Bingie Helper</summary>
        <description lang="de_DE">
            Kopiert LeoPlayer4Lastship.json in den reconfigured_players-Ordner
            von plugin.video.tmdb.bingie.helper und setzt den Standardplayer
            für Filme und Episoden automatisch.
        </description>
        <platform>all</platform>
        <language>de</language>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>