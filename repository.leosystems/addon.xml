<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.leosystems"
       name="LeoSystems Repo"
       version="1.0.0"
       provider-name="LeoSystems">

  <extension point="xbmc.addon.repository">
    <dir>
      <info compressed="false">https://raw.githubusercontent.com/leobitchy/leosystems-repo/main/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/leobitchy/leosystems-repo/main/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/leobitchy/leosystems-repo/main/</datadir>
    </dir>
  </extension>

  <extension point="xbmc.addon.metadata">
    <summary>LeoSystems Kodi Repository</summary>
    <description>LeoSystems Addons erleichtern dir Film &amp; Seriensuche in Kodi</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>

</addon>