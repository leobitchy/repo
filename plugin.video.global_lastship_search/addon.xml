<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.global_lastship_search"
       name="Globale Lastship Suche"
       version="1.0.2"
       provider-name="LeoSystems">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="kodi.context.item">
    <menu id="kodi.core.main">

      <item library="context_movie.py">
        <label>Film suchen</label>
        <visible>!IsEmpty(ListItem.Title)</visible>
      </item>

      <item library="context_tvshow.py">
        <label>Serie suchen</label>
        <visible>!IsEmpty(ListItem.Title)</visible>
      </item>

    </menu>
  </extension>

  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="de_DE">Globale Lastship Reborn Suche für Filme und Serien</summary>
    <description lang="de_DE">
      Fügt zwei globale Kontextmenüeinträge hinzu, um den ausgewählten Titel in Lastship Reborn zu suchen:
      „Film suchen“ oder „Serie suchen“.
    </description>
    <language>de</language>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>

</addon>