<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.bb_global_search"
       name="BitchyBoss Globale Kodi Suche"
       version="1.0.9"
       provider-name="BitchyBoss">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="kodi.context.item">
    <menu id="kodi.core.main">

      <item library="context_lastship.py">
        <label>Film / Serie suchen in LastShip</label>
        <visible>!IsEmpty(ListItem.Title) | !IsEmpty(ListItem.Label)</visible>
      </item>

      <item library="context_xstream.py">
        <label>Film / Serie suchen in xStream</label>
        <visible>!IsEmpty(ListItem.Title) | !IsEmpty(ListItem.Label)</visible>
      </item>

    </menu>
  </extension>

  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="de_DE">Globale LastShip und xStream Suche</summary>
    <description lang="de_DE">Fügt globale Kontextmenüeinträge hinzu, um ausgewählte Titel in LastShip Reborn oder xStream zu suchen.</description>
    <language>de</language>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>

</addon>